package converter

import (
	"fmt"
	"testing"

	"github.com/stretchr/testify/assert"
	"github.com/stretchr/testify/require"

	"lazyjira/pkg/adf"
)

// TestRoundtripStructurePreservation tests that ADF → Markdown → ADF preserves exact node types and structure
// This is the critical test to prevent HTTP 400 errors from Jira API when structure changes unexpectedly
func TestRoundtripStructurePreservation(t *testing.T) {
	tests := []struct {
		name        string
		description string
		original    adf.ADFDocument
	}{
		{
			name:        "text_node_with_link_mark_stays_text_node",
			description: "Original ADF structure: text node with link mark should remain text node with link mark",
			original: adf.ADFDocument{
				Version: 1,
				Type:    "doc",
				Content: []adf.ADFNode{
					{
						Type: adf.NodeTypeParagraph,
						Content: []adf.ADFNode{
							{
								Type: adf.NodeTypeText,
								Text: "Visit ",
							},
							{
								Type: adf.NodeTypeText,
								Text: "Google",
								Marks: []adf.ADFMark{
									{
										Type: adf.MarkTypeLink,
										Attrs: map[string]interface{}{
											"href": "https://google.com",
										},
									},
								},
							},
							{
								Type: adf.NodeTypeText,
								Text: " for search.",
							},
						},
					},
				},
			},
		},
		{
			name:        "text_node_with_atlassian_link_stays_text_node",
			description: "Atlassian URLs in text nodes should remain as text nodes, not become inlineCard",
			original: adf.ADFDocument{
				Version: 1,
				Type:    "doc",
				Content: []adf.ADFNode{
					{
						Type: adf.NodeTypeParagraph,
						Content: []adf.ADFNode{
							{
								Type: adf.NodeTypeText,
								Text: "See ",
							},
							{
								Type: adf.NodeTypeText,
								Text: "Jira ticket",
								Marks: []adf.ADFMark{
									{
										Type: adf.MarkTypeLink,
										Attrs: map[string]interface{}{
											"href": "https://company.atlassian.net/browse/PROJ-123",
										},
									},
								},
							},
							{
								Type: adf.NodeTypeText,
								Text: " for details.",
							},
						},
					},
				},
			},
		},
		{
			name:        "list_item_with_link_preserves_structure",
			description: "Links in list items should maintain exact structure to avoid HTTP 400",
			original: adf.ADFDocument{
				Version: 1,
				Type:    "doc",
				Content: []adf.ADFNode{
					{
						Type: adf.NodeTypeBulletList,
						Content: []adf.ADFNode{
							{
								Type: adf.NodeTypeListItem,
								Content: []adf.ADFNode{
									{
										Type: adf.NodeTypeText,
										Text: "Check out ",
									},
									{
										Type: adf.NodeTypeText,
										Text: "this link",
										Marks: []adf.ADFMark{
											{
												Type: adf.MarkTypeLink,
												Attrs: map[string]interface{}{
													"href": "https://example.atlassian.net/wiki/x/ABC123",
												},
											},
										},
									},
									{
										Type: adf.NodeTypeText,
										Text: " and additional text",
									},
								},
							},
						},
					},
				},
			},
		},
		{
			name:        "inlineCard_node_stays_inlineCard",
			description: "Existing inlineCard nodes should remain inlineCard nodes",
			original: adf.ADFDocument{
				Version: 1,
				Type:    "doc",
				Content: []adf.ADFNode{
					{
						Type: adf.NodeTypeParagraph,
						Content: []adf.ADFNode{
							{
								Type: adf.NodeTypeText,
								Text: "Check this out: ",
							},
							{
								Type: adf.NodeTypeInlineCard,
								Attrs: map[string]interface{}{
									"url": "https://example.com",
								},
							},
							{
								Type: adf.NodeTypeText,
								Text: " for more info.",
							},
						},
					},
				},
			},
		},
		{
			name:        "complex_internal_link_with_metadata",
			description: "Internal links with metadata should preserve all attributes",
			original: adf.ADFDocument{
				Version: 1,
				Type:    "doc",
				Content: []adf.ADFNode{
					{
						Type: adf.NodeTypeParagraph,
						Content: []adf.ADFNode{
							{
								Type: adf.NodeTypeText,
								Text: "Review the ",
							},
							{
								Type: adf.NodeTypeText,
								Text: "requirements document",
								Marks: []adf.ADFMark{
									{
										Type: adf.MarkTypeLink,
										Attrs: map[string]interface{}{
											"href":  "/projects/PROJ/pages/456",
											"title": "Requirements Document",
											"type":  "page",
											"id":    "456",
											"space": "PROJ",
										},
									},
								},
							},
							{
								Type: adf.NodeTypeText,
								Text: " for details.",
							},
						},
					},
				},
			},
		},
	}

	for _, tt := range tests {
		t.Run(tt.name, func(t *testing.T) {
			// Step 1: Perform round-trip conversion
			converter := NewDefaultConverter()
			markdown, roundtrip, err := converter.ConvertRoundTrip(tt.original)
			require.NoError(t, err, "Round-trip conversion should succeed")

			// Log the conversion for debugging
			t.Logf("Original ADF → Markdown: %s", markdown)

			// Step 2: Validate exact structure preservation
			validateStructuralEquality(t, tt.original, roundtrip)

			// Step 3: Validate that no structural transformations occurred
			validateNoStructuralTransformations(t, tt.original, roundtrip)
		})
	}
}

// validateStructuralEquality checks that two ADF documents have identical structure
func validateStructuralEquality(t *testing.T, original, roundtrip adf.ADFDocument) {
	// Document level
	assert.Equal(t, original.Version, roundtrip.Version, "Document version should be preserved")
	assert.Equal(t, original.Type, roundtrip.Type, "Document type should be preserved")
	assert.Equal(t, len(original.Content), len(roundtrip.Content), "Number of content nodes should be preserved")

	// Content level
	for i, originalNode := range original.Content {
		if i >= len(roundtrip.Content) {
			t.Fatalf("Roundtrip document missing content node at index %d", i)
		}
		roundtripNode := roundtrip.Content[i]
		validateNodeStructuralEquality(t, originalNode, roundtripNode, fmt.Sprintf("content[%d]", i))
	}
}

// validateNodeStructuralEquality recursively validates node structure
func validateNodeStructuralEquality(t *testing.T, original, roundtrip adf.ADFNode, path string) {
	// Node type must be identical
	assert.Equal(t, original.Type, roundtrip.Type,
		"Node type should be preserved at %s", path)

	// Text content must be preserved (if applicable)
	assert.Equal(t, original.Text, roundtrip.Text,
		"Text content should be preserved at %s", path)

	// Child node count must be preserved
	assert.Equal(t, len(original.Content), len(roundtrip.Content),
		"Number of child nodes should be preserved at %s", path)

	// Mark count must be preserved
	assert.Equal(t, len(original.Marks), len(roundtrip.Marks),
		"Number of marks should be preserved at %s", path)

	// Recursively validate child nodes
	for i, originalChild := range original.Content {
		if i >= len(roundtrip.Content) {
			t.Fatalf("Roundtrip node missing child at index %d in %s", i, path)
		}
		roundtripChild := roundtrip.Content[i]
		validateNodeStructuralEquality(t, originalChild, roundtripChild,
			fmt.Sprintf("%s.content[%d]", path, i))
	}

	// Validate marks
	for i, originalMark := range original.Marks {
		if i >= len(roundtrip.Marks) {
			t.Fatalf("Roundtrip node missing mark at index %d in %s", i, path)
		}
		roundtripMark := roundtrip.Marks[i]
		validateMarkStructuralEquality(t, originalMark, roundtripMark,
			fmt.Sprintf("%s.marks[%d]", path, i))
	}
}

// validateMarkStructuralEquality validates mark structure and attributes
func validateMarkStructuralEquality(t *testing.T, original, roundtrip adf.ADFMark, path string) {
	// Mark type must be identical
	assert.Equal(t, original.Type, roundtrip.Type,
		"Mark type should be preserved at %s", path)

	// All attributes must be preserved
	if original.Attrs != nil {
		assert.NotNil(t, roundtrip.Attrs,
			"Mark attributes should be preserved at %s", path)

		for key, originalValue := range original.Attrs {
			roundtripValue, exists := roundtrip.Attrs[key]
			assert.True(t, exists,
				"Mark attribute %s should be preserved at %s", key, path)
			assert.Equal(t, originalValue, roundtripValue,
				"Mark attribute %s value should be preserved at %s", key, path)
		}

		// No extra attributes should be added
		assert.Equal(t, len(original.Attrs), len(roundtrip.Attrs),
			"Mark attribute count should be preserved at %s", path)
	} else {
		assert.Nil(t, roundtrip.Attrs,
			"Mark should not have attributes if original didn't at %s", path)
	}
}

// validateNoStructuralTransformations checks for common problematic transformations
func validateNoStructuralTransformations(t *testing.T, original, roundtrip adf.ADFDocument) {
	// Check for text+link → inlineCard transformation (the main culprit)
	originalTextLinks := countTextNodesWithLinkMarks(original.Content)
	roundtripTextLinks := countTextNodesWithLinkMarks(roundtrip.Content)
	roundtripInlineCards := countInlineCardNodes(roundtrip.Content)

	assert.Equal(t, originalTextLinks, roundtripTextLinks,
		"Number of text nodes with link marks should not change")

	if originalTextLinks > 0 {
		// If we had text+link marks originally, we should not have gained inlineCard nodes
		originalInlineCards := countInlineCardNodes(original.Content)
		assert.Equal(t, originalInlineCards, roundtripInlineCards,
			"InlineCard count should not change when preserving text+link structure")
	}
}

// countTextNodesWithLinkMarks counts text nodes that have link marks
func countTextNodesWithLinkMarks(nodes []adf.ADFNode) int {
	count := 0
	for _, node := range nodes {
		if node.Type == adf.NodeTypeText {
			for _, mark := range node.Marks {
				if mark.Type == adf.MarkTypeLink {
					count++
					break // Count node once even if multiple link marks
				}
			}
		}
		// Recursively count in child nodes
		count += countTextNodesWithLinkMarks(node.Content)
	}
	return count
}

// countInlineCardNodes counts inlineCard nodes
func countInlineCardNodes(nodes []adf.ADFNode) int {
	count := 0
	for _, node := range nodes {
		if node.Type == adf.NodeTypeInlineCard {
			count++
		}
		// Recursively count in child nodes
		count += countInlineCardNodes(node.Content)
	}
	return count
}

// TestProblematicRoundtripPattern tests the specific pattern that was causing HTTP 400
func TestProblematicRoundtripPattern(t *testing.T) {
	// This is the exact pattern mentioned in tasks.md that causes HTTP 400:
	// "link + additional text in listItem"
	problematicPattern := adf.ADFDocument{
		Version: 1,
		Type:    "doc",
		Content: []adf.ADFNode{
			{
				Type: adf.NodeTypeBulletList,
				Content: []adf.ADFNode{
					{
						Type: adf.NodeTypeListItem,
						Content: []adf.ADFNode{
							{
								Type: adf.NodeTypeText,
								Text: "Atlassian link",
								Marks: []adf.ADFMark{
									{
										Type: adf.MarkTypeLink,
										Attrs: map[string]interface{}{
											"href": "https://company.atlassian.net/browse/PROJ-123",
										},
									},
								},
							},
							{
								Type: adf.NodeTypeText,
								Text: " and additional text that causes problems",
							},
						},
					},
				},
			},
		},
	}

	// Test that this pattern does NOT cause structural transformation
	converter := NewDefaultConverter()
	_, roundtrip, err := converter.ConvertRoundTrip(problematicPattern)
	require.NoError(t, err, "Problematic pattern should round-trip successfully")

	// The critical test: structure should be preserved exactly
	validateStructuralEquality(t, problematicPattern, roundtrip)
	validateNoStructuralTransformations(t, problematicPattern, roundtrip)

	t.Logf("✅ Problematic pattern handled correctly - no structural transformation")
	t.Logf("   Original: text node with link mark + additional text in listItem")
	t.Logf("   Result: text node with link mark + additional text in listItem (preserved)")
}